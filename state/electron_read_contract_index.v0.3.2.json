{
  "system": "NEXUS GATE",
  "version": "0.3.2",
  "kind": "electron_read_contract_index",
  "role": "future Electron/dashboard read contract",
  "read_surfaces": [
    "state/ai_feedback_context_latest.json",
    "docs/feedback/FEEDBACK_LOG.md",
    "docs/feedback/operator_packets/*.json",
    "reports/nexus_feedback_interface_report_latest.json",
    "reports/nexus_self_healing_report_latest.json",
    "reports/tui/nexus_tui_ai_handoff_latest.txt",
    "reports/tui/nexus_tui_snapshot_latest.html",
    "reports/tui/nexus_tui_surface_latest.json"
  ],
  "required_pairs": [
    {
      "command": "/snapshot",
      "outputs": [
        "reports/tui/nexus_tui_snapshot_latest.html",
        "reports/tui/nexus_tui_surface_latest.json"
      ]
    }
  ],
  "allowlisted_commands": [
    "evolve",
    "interface",
    "feedback",
    "heal",
    "status",
    "compact",
    "interconnect",
    "runtime",
    "pack"
  ],
  "blocked_actions": [
    "arbitrary_shell_commands",
    "external_api_write",
    "secret_access",
    "self_authorize",
    "memory_promotion_without_evidence",
    "ungated_repo_mutation",
    "mutate_graph_state",
    "bypass_evolve"
  ],
  "required_gates": [
    "python -m unittest discover -s tests",
    ".\\scripts\\nexus.ps1 evolve"
  ],
  "implementation_status": "contract_only_no_electron_app",
  "claim_boundary": "Electron read contract is local development evidence only. It does not build Electron, grant shell authority, prove correctness, prove safety, validate production readiness, or authorize autonomous action."
}
