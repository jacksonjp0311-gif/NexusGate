{
  "system": "NEXUS GATE",
  "version": "0.2.5",
  "kind": "tui_to_electron_bridge_index",
  "commands": [
    ".\\scripts\\nexus.ps1 tui",
    ".\\scripts\\nexus.ps1 ui"
  ],
  "tui_exports": [
    "reports/tui/nexus_tui_ai_handoff_latest.txt",
    "reports/tui/nexus_tui_snapshot_latest.html",
    "reports/tui/nexus_tui_surface_latest.json"
  ],
  "snapshot_bridge": {
    "surface": "reports/tui/nexus_tui_snapshot_latest.html",
    "contains": [
      "health",
      "graph status",
      "node and edge counts",
      "interconnect checks",
      "placeholder evidence paths",
      "next action"
    ]
  },
  "surface_state": {
    "surface": "reports/tui/nexus_tui_surface_latest.json",
    "contains": [
      "health",
      "graph",
      "commands",
      "surfaces",
      "blocked actions",
      "claim boundary"
    ]
  },
  "interactive_commands": [
    "/ai",
    "/copy",
    "/snapshot",
    "/electron"
  ],
  "electron_read_surfaces": [
    "state/ai_feedback_context_latest.json",
    "docs/feedback/FEEDBACK_LOG.md",
    "docs/feedback/operator_packets/*.json",
    "reports/nexus_feedback_interface_report_latest.json",
    "reports/nexus_self_healing_report_latest.json",
    "reports/tui/nexus_tui_ai_handoff_latest.txt",
    "reports/tui/nexus_tui_snapshot_latest.html",
    "reports/tui/nexus_tui_surface_latest.json"
  ],
  "electron_allowlist": [
    "evolve",
    "interface",
    "feedback",
    "heal",
    "status",
    "compact",
    "interconnect",
    "runtime",
    "pack"
  ],
  "blocked_actions": [
    "arbitrary_shell_commands",
    "external_api_write",
    "secret_access",
    "self_authorize",
    "memory_promotion_without_evidence",
    "ungated_repo_mutation"
  ],
  "claim_boundary": "Local TUI-to-Electron bridge evidence only. Does not prove correctness, safety, security, production readiness, or autonomous authority."
}
