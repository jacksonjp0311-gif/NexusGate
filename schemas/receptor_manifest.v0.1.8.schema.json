{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-gate.local/schemas/receptor_manifest.v0.1.8.json",
  "title": "NEXUS GATE ReceptorManifest v0.1.8",
  "type": "object",
  "required": [
    "receptor_id",
    "owner_adapter_id",
    "surface_type",
    "accepted_schema_families",
    "allowed_actions",
    "requires_authority_for_actions",
    "capability_bits"
  ],
