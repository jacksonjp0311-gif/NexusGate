    "receptor_id": {
      "type": "string"
    },
    "owner_adapter_id": {
      "type": "string"
    },
    "surface_type": {
      "type": "string"
    },
    "accepted_schema_families": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_authority_for_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capability_bits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_boundary": {
      "type": "string"
    }
  }
}