{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-gate.local/schemas/failure_mode.v0.1.3.json",
  "title": "NEXUS GATE FailureMode v0.1.3",
  "type": "object",
  "required": [
    "failure_id",
    "name",
    "severity",
    "trigger",
    "required_response"
  ],
  "properties": {
    "failure_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "block",
        "critical"
      ]
    },
    "trigger": {
      "type": "string"
    },
    "required_response": {
      "type": "string"
    },
    "claim_boundary": {
      "type": "string"
    }
  }
}