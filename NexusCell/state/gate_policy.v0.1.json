{
  "default": "deny",
  "hard_denies": [
    "raw_secret_exposure",
    "service_install_without_authority",
    "registry_write_without_authority",
    "unrestricted_network",
    "git_push_without_authority"
  ],
  "rules": [
    {
      "action": {
        "allow": true,
        "audit": "metadata"
      },
      "match": {
        "runner": "mock"
      },
      "name": "allow_mock_local_readonly"
    }
  ],
  "thresholds": {
    "auto": 0.3,
    "review": 0.65
  },
  "version": "0.1.0"
}
