{
  "schema": "NEXUS_TELEMETRY_SOURCES.v2.8.0",
  "version": "2.8.0",
  "sources": [
    {
      "source_id": "nws.forecast",
      "provider": "National Weather Service",
      "adapter": "nws",
      "domains": ["api.weather.gov"],
      "method": "GET",
      "endpoint_template": "https://api.weather.gov/points/{latitude},{longitude}",
      "allowed_parameters": ["latitude", "longitude"],
      "content_types": ["application/geo+json", "application/json"],
      "timeout_seconds": 15,
      "maximum_response_bytes": 2000000,
      "freshness_half_life_seconds": 1800,
      "trust_prior": 0.95,
      "location_required": true,
      "external_writes": false,
      "tasking_allowed": false
    },
    {
      "source_id": "noaa.swpc.planetary-k-index",
      "provider": "NOAA SWPC",
      "adapter": "noaa_swpc",
      "domains": ["services.swpc.noaa.gov"],
      "method": "GET",
      "endpoint_template": "https://services.swpc.noaa.gov/products/noaa-planetary-k-index.json",
      "allowed_parameters": [],
      "content_types": ["application/json"],
      "timeout_seconds": 15,
      "maximum_response_bytes": 2000000,
      "freshness_half_life_seconds": 900,
      "trust_prior": 0.95,
      "location_required": false,
      "external_writes": false,
      "tasking_allowed": false
    },
    {
      "source_id": "usgs.earthquake-significant",
      "provider": "USGS Earthquake Catalog",
      "adapter": "usgs_earthquake",
      "domains": ["earthquake.usgs.gov"],
      "method": "GET",
      "endpoint_template": "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/significant_day.geojson",
      "allowed_parameters": [],
      "content_types": ["application/geo+json", "application/json"],
      "timeout_seconds": 15,
      "maximum_response_bytes": 2000000,
      "freshness_half_life_seconds": 3600,
      "trust_prior": 0.94,
      "location_required": false,
      "external_writes": false,
      "tasking_allowed": false
    },
    {
      "source_id": "jpl.horizons.ephemeris",
      "provider": "NASA/JPL Horizons",
      "adapter": "jpl_horizons",
      "domains": ["ssd.jpl.nasa.gov"],
      "method": "GET",
      "endpoint_template": "https://ssd.jpl.nasa.gov/api/horizons.api",
      "allowed_parameters": ["COMMAND", "CENTER", "START_TIME", "STOP_TIME", "STEP_SIZE", "MAKE_EPHEM"],
      "content_types": ["application/json", "text/plain"],
      "timeout_seconds": 20,
      "maximum_response_bytes": 2000000,
      "freshness_half_life_seconds": 86400,
      "trust_prior": 0.95,
      "location_required": false,
      "external_writes": false,
      "tasking_allowed": false
    }
  ]
}
