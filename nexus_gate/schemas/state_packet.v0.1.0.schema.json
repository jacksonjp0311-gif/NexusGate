{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-gate.local/schemas/state_packet.v0.1.0.json",
  "title": "NEXUS GATE StatePacket v0.1.0",
  "type": "object",
  "required": [
    "packet_id",
    "source_framework",
    "source_surface",
    "schema_id",
    "schema_version",
    "requested_action",
    "payload"
  ],
  "properties": {
    "packet_id": { "type": "string" },
    "source_framework": { "type": "string" },
    "source_surface": { "type": "string" },
    "schema_id": { "type": "string" },
    "schema_version": { "type": "string" },
    "requested_action": {
      "type": "string",
      "enum": [
        "read_only_signal",
        "warning_signal",
        "tool_call",
        "memory_write",
        "prompt_mutation",
        "api_call",
        "filesystem_write"
      ]
    },
    "payload": { "type": "object" },
    "provenance_chain": {
      "type": "array",
      "items": { "type": "string" }
    },
    "profile_hash": { "type": ["string", "null"] },
    "origin_hash": { "type": ["string", "null"] },
    "authority_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": { "type": "object" }
  }
}